# =============================================================================
# ChinaBot environment
# Copy to .env and change secrets before deploying.
# =============================================================================

# --- Telegram bot -------------------------------------------------------------
BOT_TOKEN=
BOT_USERNAME=
SHOP_NAME=RobCargo

# --- PostgreSQL ---------------------------------------------------------------
# Historical names kept for compatibility with existing code:
# DB_NAME is the database user, DB_NAME_DATABASE is the database name.
DB_NAME=robcargo
DB_PASSWORD=change-me
# Use the same external PostgreSQL host as the website in production.
# For local development with `--profile local-db`, set DB_IP=db.
DB_IP=postgres.example.com
DB_PORT=5432
DB_NAME_DATABASE=robcargo

# --- Admins and notifications -------------------------------------------------
# Telegram numeric ids/chats. ADMIN_ID is also used to create the first bot admin.
ADMIN_ID=
ADMIN_NUMBER=
ADMIN_FORM_CHAT_ID=
ADMIN_CHAT_ID=

# --- Website integration ------------------------------------------------------
# Use http://backend:8000 when the bot is attached to the ChinaSiteCRM Docker network.
SITE_API_URL=http://backend:8000
SITE_INTEGRATION_SECRET=change-me-shared-secret
SITE_OUTBOX_ENABLED=1
SITE_OUTBOX_POLL_SECONDS=10

# --- Product-card recognition through Sub2API --------------------------------
PRODUCT_RECOGNITION_BASE_URL=https://sub2api.robcargo.my/v1
PRODUCT_RECOGNITION_API_KEY=
PRODUCT_RECOGNITION_MODEL=gemini-2.5-flash
# antigravity -> /v1/messages, chat_completions -> /v1/chat/completions
PRODUCT_RECOGNITION_API_MODE=antigravity
PRODUCT_RECOGNITION_TIMEOUT_SECONDS=45

# --- Public links shown in bot menu ------------------------------------------
CHANNEL_LINK=https://t.me/your_channel
GUIDE_LINK=https://t.me/your_guide_post
SUPPORT_TG=@your_support_username
SUPPORT_EMAIL=support@example.com
SUPPORT_HOURS=Пн-Пт 10:00-19:00

# --- Rates --------------------------------------------------------------------
# CLEAR_RATE is the internal purchase/cost CNY -> USD rate.
# DEFAULT_RATE is the client CNY -> USD rate for new users.
CLEAR_RATE=0
DEFAULT_RATE=0.1898

# Optional rates used only by Excel exporters.
YUAN_TO_RUB=15
YUAN_TO_BYN=0.34

# Optional absolute paths to custom XLSX templates.
CARGO_XLSX_TEMPLATE=
EXPEDITION_XLSX_TEMPLATE=
